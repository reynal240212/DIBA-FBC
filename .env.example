# Configuración de Variables de Entorno

# URL de tu proyecto Supabase (ej: https://xyz.supabase.co)
SUPABASE_URL=

# Clave Anónima (para el frontend)
SUPABASE_ANON_KEY=

# Clave de Rol de Servicio (¡SOLO para scripts de backend como create_admin.js!)
# NUNCA expongas esta clave en el frontend.
SUPABASE_SERVICE_ROLE_KEY=
